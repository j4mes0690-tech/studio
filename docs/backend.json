{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SubContractor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubContractor",
      "type": "object",
      "description": "Represents an external partner such as a subcontractor, designer, or supplier.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isSubContractor": { "type": "boolean" },
        "isDesigner": { "type": "boolean" },
        "isSupplier": { "type": "boolean" },
        "isPlantSupplier": { "type": "boolean" }
      },
      "required": ["id", "name", "email"]
    },
    "PlantOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlantOrder",
      "type": "object",
      "description": "Represents a hire contract for construction plant or machinery.",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "description": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "onHireDate": { "type": "string", "format": "date" },
              "anticipatedOffHireDate": { "type": "string", "format": "date" },
              "actualOffHireDate": { "type": ["string", "null"], "format": "date" },
              "rate": { "type": "number" },
              "rateUnit": { "type": "string", "enum": ["daily", "weekly", "monthly", "item"] },
              "status": { "type": "string", "enum": ["scheduled", "on-hire", "off-hired"] }
            }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "on-hire", "off-hired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "reference", "projectId", "supplierId", "description", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/sub-contractors/{subId}", "definition": { "entityName": "SubContractor" } },
      { "path": "/plant-orders/{orderId}", "definition": { "entityName": "PlantOrder" } }
    ]
  }
}
