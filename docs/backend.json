
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "canManageTraining": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" },
            "accessMaterials": { "type": "boolean" },
            "accessPlant": { "type": "boolean" },
            "accessVariations": { "type": "boolean" },
            "accessPermits": { "type": "boolean" },
            "accessTraining": { "type": "boolean" },
            "accessClientInstructions": { "type": "boolean" },
            "accessSiteInstructions": { "type": "boolean" },
            "accessCleanupNotices": { "type": "boolean" },
            "accessSnagging": { "type": "boolean" },
            "accessQualityControl": { "type": "boolean" },
            "accessInfoRequests": { "type": "boolean" },
            "accessPaymentNotices": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "siteManager": { "type": "string" },
        "siteManagerPhone": { "type": "string" },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SubContractor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubContractor",
      "type": "object",
      "description": "Represents an external partner such as a subcontractor, designer, or supplier.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "isSubContractor": { "type": "boolean" },
        "isDesigner": { "type": "boolean" },
        "isSupplier": { "type": "boolean" },
        "isPlantSupplier": { "type": "boolean" }
      },
      "required": ["id", "name", "email"]
    },
    "PaymentNotice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PaymentNotice",
      "type": "object",
      "description": "Represents a payment notice lifecycle for a subcontractor.",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "subcontractorId": { "type": "string" },
        "subcontractorName": { "type": "string" },
        "period": { "type": "string" },
        "applicationReceivedDate": { "type": ["string", "null"], "format": "date" },
        "certificateIssuedDate": { "type": ["string", "null"], "format": "date" },
        "invoiceReceivedDate": { "type": ["string", "null"], "format": "date" },
        "invoiceUploadedDate": { "type": ["string", "null"], "format": "date" },
        "status": { "type": "string", "enum": ["pending", "certified", "invoiced", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "subcontractorId", "period"]
    },
    "ValuationPeriod": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ValuationPeriod",
      "type": "object",
      "description": "Represents a formal monthly valuation cycle folder.",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "string" },
        "label": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "value", "label"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/sub-contractors/{subId}", "definition": { "entityName": "SubContractor" } },
      { "path": "/cleanup-notices/{id}", "definition": { "entityName": "CleanUpNotice" } },
      { "path": "/snagging-items/{id}", "definition": { "entityName": "SnaggingItem" } },
      { "path": "/information-requests/{id}", "definition": { "entityName": "InformationRequest" } },
      { "path": "/quality-checklists/{id}", "definition": { "entityName": "QualityChecklist" } },
      { "path": "/purchase-orders/{id}", "definition": { "entityName": "PurchaseOrder" } },
      { "path": "/plant-orders/{id}", "definition": { "entityName": "PlantOrder" } },
      { "path": "/variations/{id}", "definition": { "entityName": "Variation" } },
      { "path": "/training-records/{id}", "definition": { "entityName": "TrainingRecord" } },
      { "path": "/training-needs/{id}", "definition": { "entityName": "TrainingNeed" } },
      { "path": "/payment-notices/{id}", "definition": { "entityName": "PaymentNotice" } },
      { "path": "/valuation-periods/{id}", "definition": { "entityName": "ValuationPeriod" } }
    ]
  }
}
