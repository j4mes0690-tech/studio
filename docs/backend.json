
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SubContractor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubContractor",
      "type": "object",
      "description": "Represents an external partner such as a subcontractor, designer, or supplier.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isSubContractor": { "type": "boolean" },
        "isDesigner": { "type": "boolean" },
        "isSupplier": { "type": "boolean" }
      },
      "required": ["id", "name", "email"]
    },
    "QualityChecklist": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QualityChecklist",
      "type": "object",
      "description": "Represents a quality checklist template or instance.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "trade": { "type": "string" },
        "isTemplate": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "yes", "no", "na"] }
            }
          }
        }
      },
      "required": ["id", "title", "trade", "items"]
    },
    "Material": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Material",
      "type": "object",
      "description": "Represents a material that can be ordered.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "defaultPrice": { "type": "number" }
      },
      "required": ["id", "name", "unit"]
    },
    "PurchaseOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PurchaseOrder",
      "type": "object",
      "description": "Represents a formal request for materials from a supplier.",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "supplierId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "issued", "received", "cancelled"] },
        "totalAmount": { "type": "number" }
      },
      "required": ["id", "orderNumber", "projectId", "supplierId", "status"]
    },
    "Permit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Permit",
      "type": "object",
      "description": "Represents an electronic Permit to Work with dynamic AI-generated fields.",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "areaId": { "type": "string" },
        "type": { "type": "string", "enum": ["Hot Work", "Confined Space", "Excavation", "Lifting", "General"] },
        "contractorId": { "type": "string" },
        "contractorName": { "type": "string" },
        "description": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "label": { "type": "string" },
                    "type": { "type": "string", "enum": ["text", "textarea", "checkbox"] },
                    "value": { "type": ["string", "boolean"] }
                  }
                }
              }
            }
          }
        },
        "validFrom": { "type": "string", "format": "date-time" },
        "validTo": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "issued", "closed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["id", "reference", "projectId", "type", "contractorId", "status"]
    },
    "PermitTemplate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PermitTemplate",
      "type": "object",
      "description": "Dynamic template for specific permit types, generated by AI.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Hot Work", "Confined Space", "Excavation", "Lifting", "General"] },
        "description": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "label": { "type": "string" },
                    "type": { "type": "string", "enum": ["text", "textarea", "checkbox"] }
                  }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "sections"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/sub-contractors/{subId}", "definition": { "entityName": "SubContractor" } },
      { "path": "/quality-checklists/{checklistId}", "definition": { "entityName": "QualityChecklist" } },
      { "path": "/materials/{materialId}", "definition": { "entityName": "Material" } },
      { "path": "/purchase-orders/{orderId}", "definition": { "entityName": "PurchaseOrder" } },
      { "path": "/permits/{permitId}", "definition": { "entityName": "Permit" } },
      { "path": "/permit-templates/{templateId}", "definition": { "entityName": "PermitTemplate" } }
    ]
  }
}
