
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "userType": { "type": "string", "enum": ["internal", "partner"] },
        "subContractorId": { "type": "string", "description": "Association with an external partner or designer company." },
        "requirePasswordChange": { "type": "boolean" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "canManageTraining": { "type": "boolean" },
            "canManageIRS": { "type": "boolean" },
            "canApproveHolidays": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" },
            "accessMaterials": { "type": "boolean" },
            "accessPlant": { "type": "boolean" },
            "accessVariations": { "type": "boolean" },
            "accessPermits": { "type": "boolean" },
            "accessTraining": { "type": "boolean" },
            "accessClientInstructions": { "type": "boolean" },
            "accessSiteInstructions": { "type": "boolean" },
            "accessCleanupNotices": { "type": "boolean" },
            "accessSnagging": { "type": "boolean" },
            "accessQualityControl": { "type": "boolean" },
            "accessInfoRequests": { "type": "boolean" },
            "accessPaymentNotices": { "type": "boolean" },
            "accessSubContractOrders": { "type": "boolean" },
            "accessIRS": { "type": "boolean" },
            "accessPlanner": { "type": "boolean" },
            "accessProcurement": { "type": "boolean" },
            "accessHolidays": { "type": "boolean" },
            "accessSiteDiary": { "type": "boolean" },
            "accessDocuments": { "type": "boolean" },
            "accessSitePhotos": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "SiteProgressPhoto": {
      "title": "Site Progress Photo",
      "description": "A record of site progress photos linked to a project and optional area.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "areaId": { "type": "string", "nullable": true },
        "description": { "type": "string" },
        "photos": { "type": "array", "items": { "$ref": "#/backend/entities/Photo" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["id", "projectId", "photos", "createdAt"]
    },
    "DrawingDocument": {
      "title": "Drawing Document",
      "description": "A technical drawing or project document managed in the register.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "reference": { "type": "string" },
        "revision": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "superseded", "draft"] },
        "approvalStatus": { "type": "string", "enum": ["awaiting", "status-a", "status-b", "status-c"] },
        "messages": { "type": "array", "items": { "$ref": "#/backend/entities/ChatMessage" } },
        "file": { "$ref": "#/backend/entities/FileAttachment" },
        "sharepointUrl": { "type": "string", "format": "uri" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "senderEmail": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "photos": { "type": "array", "items": { "$ref": "#/backend/entities/Photo" } },
        "files": { "type": "array", "items": { "$ref": "#/backend/entities/FileAttachment" } }
      }
    },
    "Photo": {
      "title": "Photo",
      "type": "object",
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "takenAt": { "type": "string", "format": "date-time" }
      }
    },
    "FileAttachment": {
      "title": "File Attachment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "size": { "type": "number" }
      }
    },
    "HolidayRequest": {
      "title": "Holiday Request",
      "description": "A staff leave or holiday request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "totalDays": { "type": "number" },
        "type": { "type": "string", "enum": ["holiday", "sick", "other"] },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approvedByEmail": { "type": "string" },
        "approvedByName": { "type": "string" },
        "lineManagerEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "dismissedBy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global application configurations such as branding and company metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" }
      }
    },
    "ToolboxTalkTemplate": {
      "title": "Toolbox Talk Template",
      "description": "A template for site educational safety briefings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "trade": { "type": "string" },
        "verificationItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "System user profiles." },
    "/projects/{projectId}": { "schema": { "$ref": "#/backend/entities/Project" }, "description": "Construction site project metadata." },
    "/irs-items/{id}": { "schema": { "$ref": "#/backend/entities/IRSItem" }, "description": "Information Required Schedule tracking items." },
    "/planner-tasks/{id}": { "schema": { "$ref": "#/backend/entities/PlannerTask" }, "description": "Short term construction planning tasks." },
    "/procurement-items/{id}": { "schema": { "$ref": "#/backend/entities/ProcurementItem" }, "description": "Trade procurement scheduling and tracking." },
    "/system-settings/{id}": { "schema": { "$ref": "#/backend/entities/SystemSettings" }, "description": "Global app configurations." },
    "/holiday-requests/{id}": { "schema": { "$ref": "#/backend/entities/HolidayRequest" }, "description": "Staff leave and holiday requests." },
    "/site-diary/{id}": { "schema": { "$ref": "#/backend/entities/SiteDiaryEntry" }, "description": "Daily site logs and labour records." },
    "/drawings/{id}": { "schema": { "$ref": "#/backend/entities/DrawingDocument" }, "description": "Project drawings and technical document register." },
    "/snagging-items/{id}": { "schema": { "$ref": "#/backend/entities/SnaggingItem" }, "description": "Area snagging and defect management lists." },
    "/toolbox-talk-templates/{id}": { "schema": { "$ref": "#/backend/entities/ToolboxTalkTemplate" }, "description": "Master library of safety briefings." },
    "/site-photos/{id}": { "schema": { "$ref": "#/backend/entities/SiteProgressPhoto" }, "description": "Standalone site progress photos." }
  }
}
