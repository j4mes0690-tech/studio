
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "userType": { "type": "string", "enum": ["internal", "partner"] },
        "subContractorId": { "type": "string", "description": "Association with an external partner or designer company." },
        "requirePasswordChange": { "type": "boolean" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "canManageTraining": { "type": "boolean" },
            "canManageIRS": { "type": "boolean" },
            "canApproveHolidays": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" },
            "accessMaterials": { "type": "boolean" },
            "accessPlant": { "type": "boolean" },
            "accessVariations": { "type": "boolean" },
            "accessPermits": { "type": "boolean" },
            "accessTraining": { "type": "boolean" },
            "accessClientInstructions": { "type": "boolean" },
            "accessSiteInstructions": { "type": "boolean" },
            "accessCleanupNotices": { "type": "boolean" },
            "accessSnagging": { "type": "boolean" },
            "accessQualityControl": { "type": "boolean" },
            "accessInfoRequests": { "type": "boolean" },
            "accessPaymentNotices": { "type": "boolean" },
            "accessSubContractOrders": { "type": "boolean" },
            "accessIRS": { "type": "boolean" },
            "accessPlanner": { "type": "boolean" },
            "accessProcurement": { "type": "boolean" },
            "accessHolidays": { "type": "boolean" },
            "accessSiteDiary": { "type": "boolean" },
            "accessDocuments": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "DrawingDocument": {
      "title": "Drawing Document",
      "description": "A technical drawing or project document managed in the register.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "reference": { "type": "string" },
        "revision": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "superseded", "draft"] },
        "file": { "$ref": "#/backend/entities/FileAttachment" },
        "sharepointUrl": { "type": "string", "format": "uri" },
        "lastSyncedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      }
    },
    "FileAttachment": {
      "title": "File Attachment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "type": { "type": "string" },
        "size": { "type": "number" }
      }
    },
    "HolidayRequest": {
      "title": "Holiday Request",
      "description": "A staff leave or holiday request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "totalDays": { "type": "number" },
        "type": { "type": "string", "enum": ["holiday", "sick", "other"] },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approvedByEmail": { "type": "string" },
        "approvedByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "Global application configurations such as branding and company metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "companyName": { "type": "string" },
        "companyAddress": { "type": "string" }
      }
    },
    "PlannerTask": {
      "title": "Planner Task",
      "description": "A specific work item in the short term construction schedule.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "plannerId": { "type": "string" },
        "title": { "type": "string" },
        "subcontractorId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "durationDays": { "type": "number" },
        "originalStartDate": { "type": "string", "format": "date" },
        "originalDurationDays": { "type": "number" },
        "actualCompletionDate": { "type": "string", "format": "date" },
        "predecessorIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProcurementItem": {
      "title": "Procurement Item",
      "description": "Represents an entry in the procurement schedule for a project trade.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "trade": { "type": "string" },
        "subcontractorId": { "type": "string" },
        "subcontractorName": { "type": "string" },
        "warrantyRequired": { "type": "boolean" },
        "targetEnquiryDate": { "type": "string", "format": "date" },
        "tenderPeriodWeeks": { "type": "number" },
        "actualEnquiryDate": { "type": "string", "format": "date" },
        "tenderReturnDate": { "type": "string", "format": "date" },
        "latestDateForOrder": { "type": "string", "format": "date" },
        "leadInPeriodWeeks": { "type": "number" },
        "startOnSiteDate": { "type": "string", "format": "date" },
        "preContractMeetingDate": { "type": "string", "format": "date" },
        "orderPlacedDate": { "type": "string", "format": "date" },
        "comments": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "enquiry", "tender-returned", "ordered", "on-site"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "IRSItem": {
      "title": "IRS Item",
      "description": "Information Required Schedule item tracking design deliverables.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedToEmail": { "type": "string" },
        "requiredByDate": { "type": "string", "format": "date" },
        "notificationLeadDays": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "provided", "overdue", "escalated"] },
        "escalatedRfiId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Represents a construction project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "siteManager": { "type": "string" },
        "siteManagerPhone": { "type": "string" },
        "planners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SiteDiaryEntry": {
      "title": "Site Diary Entry",
      "description": "Daily record of site activities, weather, and labor resources.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "weather": {
          "type": "object",
          "properties": {
            "condition": { "type": "string" },
            "temp": { "type": "number" },
            "notes": { "type": "string" }
          }
        },
        "subcontractorLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subcontractorId": { "type": "string" },
              "subcontractorName": { "type": "string" },
              "employeeCount": { "type": "number" },
              "areaId": { "type": "string" },
              "areaName": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "generalComments": { "type": "string" },
        "photos": { "type": "array", "items": { "$ref": "#/backend/entities/Photo" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["id", "projectId", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "System user profiles." },
    "/projects/{projectId}": { "schema": { "$ref": "#/backend/entities/Project" }, "description": "Construction site project metadata." },
    "/irs-items/{id}": { "schema": { "$ref": "#/backend/entities/IRSItem" }, "description": "Information Required Schedule tracking items." },
    "/planner-tasks/{id}": { "schema": { "$ref": "#/backend/entities/PlannerTask" }, "description": "Short term construction planning tasks." },
    "/procurement-items/{id}": { "schema": { "$ref": "#/backend/entities/ProcurementItem" }, "description": "Trade procurement scheduling and tracking." },
    "/system-settings/{id}": { "schema": { "$ref": "#/backend/entities/SystemSettings" }, "description": "Global app configurations." },
    "/holiday-requests/{id}": { "schema": { "$ref": "#/backend/entities/HolidayRequest" }, "description": "Staff leave and holiday requests." },
    "/site-diary/{id}": { "schema": { "$ref": "#/backend/entities/SiteDiaryEntry" }, "description": "Daily site logs and labor records." },
    "/drawings/{id}": { "schema": { "$ref": "#/backend/entities/DrawingDocument" }, "description": "Project drawings and technical document register." }
  }
}
