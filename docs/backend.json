
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "role"]
    },
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a client for whom construction projects are undertaken.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name", "contactPerson", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "clientId", "name", "status"]
    },
    "SubContractor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubContractor",
      "type": "object",
      "description": "Represents an external partner such as a subcontractor, designer, or supplier.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isSubContractor": { "type": "boolean" },
        "isDesigner": { "type": "boolean" },
        "isSupplier": { "type": "boolean" },
        "trades": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "email"]
    },
    "Material": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Material",
      "type": "object",
      "description": "Represents a material that can be ordered.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "defaultPrice": { "type": "number" }
      },
      "required": ["id", "name", "unit"]
    },
    "PurchaseOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PurchaseOrder",
      "type": "object",
      "description": "Represents a formal request for materials from a supplier.",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "supplierId": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" }
      },
      "required": ["id", "orderNumber", "projectId", "supplierId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/sub-contractors/{subId}", "definition": { "entityName": "SubContractor" } },
      { "path": "/materials/{materialId}", "definition": { "entityName": "Material" } },
      { "path": "/purchase-orders/{orderId}", "definition": { "entityName": "PurchaseOrder" } }
    ]
  }
}
