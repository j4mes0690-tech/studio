
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "requirePasswordChange": { "type": "boolean", "description": "Flag to prompt user to update password after a reset." },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "canManageTraining": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" },
            "accessMaterials": { "type": "boolean" },
            "accessPlant": { "type": "boolean" },
            "accessVariations": { "type": "boolean" },
            "accessPermits": { "type": "boolean" },
            "accessTraining": { "type": "boolean" },
            "accessClientInstructions": { "type": "boolean" },
            "accessSiteInstructions": { "type": "boolean" },
            "accessCleanupNotices": { "type": "boolean" },
            "accessSnagging": { "type": "boolean" },
            "accessQualityControl": { "type": "boolean" },
            "accessInfoRequests": { "type": "boolean" },
            "accessPaymentNotices": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a construction project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "siteManager": { "type": "string" },
        "siteManagerPhone": { "type": "string" },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    },
    "SubContractor": {
      "title": "SubContractor",
      "description": "Represents an external partner such as a subcontractor, designer, or supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "isSubContractor": { "type": "boolean" },
        "isDesigner": { "type": "boolean" },
        "isSupplier": { "type": "boolean" },
        "isPlantSupplier": { "type": "boolean" }
      },
      "required": ["id", "name", "email"]
    },
    "ClientInstruction": {
      "title": "ClientInstruction",
      "description": "A directive received from the client for implementation on site.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "originalText": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentNotice": {
      "title": "PaymentNotice",
      "description": "Represents a payment notice lifecycle for a subcontractor.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "subcontractorId": { "type": "string" },
        "subcontractorName": { "type": "string" },
        "period": { "type": "string" },
        "isValuationDue": { "type": "boolean" },
        "applicationReceivedDate": { "type": ["string", "null"], "format": "date" },
        "certificateIssuedDate": { "type": ["string", "null"], "format": "date" },
        "invoiceReceivedDate": { "type": ["string", "null"], "format": "date" },
        "invoiceUploadedDate": { "type": ["string", "null"], "format": "date" },
        "status": { "type": "string", "enum": ["pending", "certified", "invoiced", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "subcontractorId", "period"]
    },
    "ValuationPeriod": {
      "title": "ValuationPeriod",
      "description": "Represents a formal monthly valuation cycle folder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "value": { "type": "string" },
        "label": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "value", "label"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "A formal request for materials from a supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "PlantOrder": {
      "title": "PlantOrder",
      "description": "A contract forconstruction equipment hire.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Permit": {
      "title": "Permit",
      "description": "An electronic permit-to-work for high-risk activities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "TrainingRecord": {
      "title": "TrainingRecord",
      "description": "A staff training certificate or qualification record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "courseName": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" }
      }
    },
    "TrainingNeed": {
      "title": "TrainingNeed",
      "description": "An identified training gap or requirement for an employee.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "courseName": { "type": "string" },
        "priority": { "type": "string" }
      }
    },
    "Trade": {
      "title": "Trade",
      "description": "A construction trade or discipline category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "System user profiles." },
    "/projects/{projectId}": { "schema": { "$ref": "#/backend/entities/Project" }, "description": "Construction site project metadata." },
    "/sub-contractors/{subId}": { "schema": { "$ref": "#/backend/entities/SubContractor" }, "description": "External trade partner directory." },
    "/client-instructions/{id}": { "schema": { "$ref": "#/backend/entities/ClientInstruction" }, "description": "Directives from the client." },
    "/instructions/{id}": { "schema": "Instruction", "description": "Site instructions for contractors." },
    "/cleanup-notices/{id}": { "schema": "CleanUpNotice", "description": "Formal cleaning requirements." },
    "/snagging-items/{id}": { "schema": "SnaggingItem", "description": "Defect logs and items." },
    "/information-requests/{id}": { "schema": "InformationRequest", "description": "Technical queries (RFI)." },
    "/quality-checklists/{id}": { "schema": "QualityChecklist", "description": "Trade verification checklists." },
    "/purchase-orders/{id}": { "schema": { "$ref": "#/backend/entities/PurchaseOrder" }, "description": "Material procurement records." },
    "/plant-orders/{id}": { "schema": { "$ref": "#/backend/entities/PlantOrder" }, "description": "Equipment hire contracts." },
    "/permits/{id}": { "schema": { "$ref": "#/backend/entities/Permit" }, "description": "Electronic safety permits." },
    "/permit-templates/{id}": { "schema": "PermitTemplate", "description": "Master permit layouts." },
    "/variations/{id}": { "schema": "Variation", "description": "Financial cost changes." },
    "/training-records/{id}": { "schema": { "$ref": "#/backend/entities/TrainingRecord" }, "description": "Staff certifications." },
    "/training-needs/{id}": { "schema": { "$ref": "#/backend/entities/TrainingNeed" }, "description": "Future training requirements." },
    "/payment-notices/{id}": { "schema": { "$ref": "#/backend/entities/PaymentNotice" }, "description": "Subcontractor payment lifecycle." },
    "/valuation-periods/{id}": { "schema": { "$ref": "#/backend/entities/ValuationPeriod" }, "description": "Monthly valuation cycles." },
    "/trades/{id}": { "schema": { "$ref": "#/backend/entities/Trade" }, "description": "Master list of trade disciplines." }
  }
}
