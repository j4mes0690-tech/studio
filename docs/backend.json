
{
  "entities": {
    "DistributionUser": {
      "title": "DistributionUser",
      "description": "A user profile with system permissions and internal credentials.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string", "description": "Internal system password for the user." },
        "permissions": { "$ref": "#/entities/UserPermissions" }
      },
      "required": ["name", "email", "password"]
    },
    "UserPermissions": {
      "title": "UserPermissions",
      "description": "Access control flags for various system modules.",
      "type": "object",
      "properties": {
        "canManageUsers": { "type": "boolean" },
        "canManageSubcontractors": { "type": "boolean" },
        "canManageProjects": { "type": "boolean" },
        "canManageChecklists": { "type": "boolean" },
        "hasFullVisibility": { "type": "boolean", "description": "Whether the user can see all data across all projects." }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A construction project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "assignedUsers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Emails of users allowed to access this project."
        },
        "areas": {
          "type": "array",
          "items": { "$ref": "#/entities/Area" }
        }
      },
      "required": ["name"]
    },
    "Area": {
      "title": "Area",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Instruction": {
      "title": "Instruction",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "originalText": { "type": "string" },
        "summary": { "type": "string" },
        "actionItems": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "recipients": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "$ref": "#/entities/Photo" } }
      }
    },
    "ClientInstruction": {
      "title": "ClientInstruction",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "originalText": { "type": "string" },
        "summary": { "type": "string" },
        "actionItems": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "recipients": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "$ref": "#/entities/Photo" } }
      }
    },
    "Photo": {
      "title": "Photo",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "takenAt": { "type": "string" }
      }
    },
    "SubContractor": {
      "title": "SubContractor",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "CleanUpNotice": {
      "title": "CleanUpNotice",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "recipients": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "$ref": "#/entities/Photo" } }
      }
    },
    "SnaggingItem": {
      "title": "SnaggingItem",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "areaId": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "photos": { "type": "array", "items": { "$ref": "#/entities/Photo" } }
      }
    },
    "InformationRequest": {
      "title": "InformationRequest",
      "description": "RFIs.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "array", "items": { "type": "string" } },
        "raisedBy": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "requiredBy": { "type": "string" },
        "messages": { "type": "array", "items": { "$ref": "#/entities/ChatMessage" } },
        "dismissedBy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string" },
        "senderEmail": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "QualityChecklist": {
      "title": "QualityChecklist",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "areaId": { "type": "string" },
        "title": { "type": "string" },
        "trade": { "type": "string" },
        "createdAt": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/ChecklistItem" } },
        "recipients": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ChecklistItem": {
      "title": "ChecklistItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "yes", "no", "na"] },
        "comment": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "DistributionUser",
      "description": "Internal user profiles."
    },
    "/projects/{id}": {
      "schema": "Project",
      "description": "Project records."
    },
    "/sub-contractors/{id}": {
      "schema": "SubContractor",
      "description": "Registered sub-contractors."
    },
    "/instructions/{id}": {
      "schema": "Instruction",
      "description": "On-site instructions."
    },
    "/client-instructions/{id}": {
      "schema": "ClientInstruction",
      "description": "Directives from the client."
    },
    "/cleanup-notices/{id}": {
      "schema": "CleanUpNotice",
      "description": "Cleanup requests."
    },
    "/snagging-items/{id}": {
      "schema": "SnaggingItem",
      "description": "Defect tracking items."
    },
    "/information-requests/{id}": {
      "schema": "InformationRequest",
      "description": "RFIs."
    },
    "/quality-checklists/{id}": {
      "schema": "QualityChecklist",
      "description": "Trade checklists and templates."
    }
  }
}
