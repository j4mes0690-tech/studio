
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application, such as a site team member or administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "userType": { "type": "string", "enum": ["internal", "partner"] },
        "subContractorId": { "type": "string", "description": "Association with an external partner or designer company." },
        "requirePasswordChange": { "type": "boolean" },
        "permissions": {
          "type": "object",
          "properties": {
            "canManageUsers": { "type": "boolean" },
            "canManageSubcontractors": { "type": "boolean" },
            "canManageProjects": { "type": "boolean" },
            "canManageChecklists": { "type": "boolean" },
            "canManageMaterials": { "type": "boolean" },
            "canManagePermitTemplates": { "type": "boolean" },
            "canManageTraining": { "type": "boolean" },
            "canManageIRS": { "type": "boolean" },
            "hasFullVisibility": { "type": "boolean" },
            "accessMaterials": { "type": "boolean" },
            "accessPlant": { "type": "boolean" },
            "accessVariations": { "type": "boolean" },
            "accessPermits": { "type": "boolean" },
            "accessTraining": { "type": "boolean" },
            "accessClientInstructions": { "type": "boolean" },
            "accessSiteInstructions": { "type": "boolean" },
            "accessCleanupNotices": { "type": "boolean" },
            "accessSnagging": { "type": "boolean" },
            "accessQualityControl": { "type": "boolean" },
            "accessInfoRequests": { "type": "boolean" },
            "accessPaymentNotices": { "type": "boolean" },
            "accessSubContractOrders": { "type": "boolean" },
            "accessIRS": { "type": "boolean" },
            "accessPlanner": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "email"]
    },
    "PlannerTask": {
      "title": "Planner Task",
      "description": "A specific work item in the short term planner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "areaId": { "type": "string" },
        "title": { "type": "string" },
        "tradeId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "durationDays": { "type": "number" },
        "predecessorIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "title", "tradeId", "startDate", "durationDays"]
    },
    "IRSItem": {
      "title": "IRS Item",
      "description": "Information Required Schedule item tracking design deliverables.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedToEmail": { "type": "string" },
        "requiredByDate": { "type": "string", "format": "date" },
        "notificationLeadDays": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "provided", "overdue", "escalated"] },
        "escalatedRfiId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["id", "projectId", "title", "requiredByDate", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a construction project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "siteManager": { "type": "string" },
        "siteManagerPhone": { "type": "string" },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "assignedUsers": { "type": "array", "items": { "type": "string" } },
        "assignedSubContractors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/User" }, "description": "System user profiles." },
    "/projects/{projectId}": { "schema": { "$ref": "#/backend/entities/Project" }, "description": "Construction site project metadata." },
    "/irs-items/{id}": { "schema": { "$ref": "#/backend/entities/IRSItem" }, "description": "Information Required Schedule tracking items." },
    "/planner-tasks/{id}": { "schema": { "$ref": "#/backend/entities/PlannerTask" }, "description": "Short term construction planning tasks." }
  }
}
