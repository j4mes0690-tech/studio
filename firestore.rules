rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE SECURITY RULES:
     * These rules allow authenticated users (including anonymous ones) to access
     * all collections. 
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Allow all authenticated access to core collections for prototype development
    match /users/{userId} { allow read, write: if isSignedIn(); }
    match /projects/{projectId} { allow read, write: if isSignedIn(); }
    match /sub-contractors/{subId} { allow read, write: if isSignedIn(); }
    match /client-instructions/{id} { allow read, write: if isSignedIn(); }
    match /instructions/{id} { allow read, write: if isSignedIn(); }
    match /cleanup-notices/{id} { allow read, write: if isSignedIn(); }
    match /snagging-items/{id} { allow read, write: if isSignedIn(); }
    match /information-requests/{id} { allow read, write: if isSignedIn(); }
    match /quality-checklists/{id} { allow read, write: if isSignedIn(); }
    match /suppliers/{supplierId} { allow read, write: if isSignedIn(); }
    match /materials/{materialId} { allow read, write: if isSignedIn(); }
    match /purchase-orders/{orderId} { allow read, write: if isSignedIn(); }
    match /trades/{tradeId} { allow read, write: if isSignedIn(); }
    match /permits/{permitId} { allow read, write: if isSignedIn(); }
    match /permit-templates/{templateId} { allow read, write: if isSignedIn(); }
    match /plant-orders/{orderId} { allow read, write: if isSignedIn(); }
    match /variations/{id} { allow read, write: if isSignedIn(); }
  }
}
