rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // allow the login form to check for user existence and verify passwords
    // Note: This is required because Firebase Auth is bypassed.
    match /users/{userEmail} {
      allow read: if true;
      // only allow logged-in users (from the app's perspective) to update profiles
      // in a real app, you'd want more complex logic here since request.auth is null
      allow write: if true; 
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if true;
    }
  }
}