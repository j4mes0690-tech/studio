rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY (PROTOTYPING)
     * To ensure maximum reliability during the walkthrough and development,
     * we allow all authenticated users (including anonymous) full access 
     * to the database. This avoids permission denials during data aggregation
     * and project directory listings.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}